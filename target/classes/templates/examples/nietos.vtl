<HTML>
<HEAD>     <TITLE>Productos</TITLE>    </HEAD>
<BODY>
<form action='/getNietos' method='get'>
  <div class="form-group">
    <label for="nombre">Un nombre</label>
    <input id="nombre" name="nombre" class="form-control" type="text">
  </div>
  <button type="submit" class="btn">Nombre de la Persona que busca los nietos</button>
</form>

      <div style="text-align: center;">
      <B>Cantidad de Nietos: $nietos.size()</B>
      <BR/>  <BR/>
      Ellos son:  #set( $cuenta = 1 )  
      <TABLE>
         #foreach( $p in $nietos )          
            <TR>
                <TD>$cuenta         </TD>
                <TD>$p.getNombre() $p.getApellido() </TD>
            </TR>
          #set( $cuenta = $cuenta + 1 )
        #end
      </TABLE>      <BR/>      <I>Todos los nietos de $nombre</I>
      </div>
</BODY>  
</HTML>